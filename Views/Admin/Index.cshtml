@using EmployeeLeaveManagement.Models

@{
    var leaveRequests = ViewBag.LeaveRequests as List<LeaveRequest>;
}

<div class="container-box">
    <h2>Admin Dashboard</h2>

    <div style="display:flex; gap:20px; margin-bottom:30px; flex-wrap:wrap;">
        <div style="background:#4f46e5; color:white; padding:20px; border-radius:15px; min-width:180px;">
            <h3>@ViewBag.TotalEmployees</h3>
            <p>Total Employees</p>
        </div>

        <div style="background:#f59e0b; color:white; padding:20px; border-radius:15px; min-width:180px;">
            <h3>@ViewBag.PendingLeaves</h3>
            <p>Pending Leaves</p>
        </div>

        <div style="background:#16a34a; color:white; padding:20px; border-radius:15px; min-width:180px;">
            <h3>@ViewBag.ApprovedLeaves</h3>
            <p>Approved Leaves</p>
        </div>

        <div style="background:#dc2626; color:white; padding:20px; border-radius:15px; min-width:180px;">
            <h3>@ViewBag.RejectedLeaves</h3>
            <p>Rejected Leaves</p>
        </div>
    </div>

    <h3>Manage Leave Requests</h3>

    <table>
        <tr>
            <th>Employee</th>
            <th>Leave Type</th>
            <th>From</th>
            <th>To</th>
            <th>Status</th>
            <th>Action</th>
        </tr>

        @foreach (var leave in leaveRequests)
        {
            <tr>
                <td>@leave.EmployeeName</td>
                <td>@leave.LeaveType</td>
                <td>@leave.FromDate.ToShortDateString()</td>
                <td>@leave.ToDate.ToShortDateString()</td>
                <td>@leave.Status</td>
                <td>
                    @if (leave.Status == "Pending")
                    {
                        <a href="/Admin/Approve/@leave.Id" class="btn" style="background:#16a34a;">
                            Approve
                        </a>

                        <a href="/Admin/Reject/@leave.Id" class="btn" style="background:#dc2626; margin-left:8px;">
                            Reject
                        </a>
                    }
                </td>
            </tr>
        }
    </table>
</div>