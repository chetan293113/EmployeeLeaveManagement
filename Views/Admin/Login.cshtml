@model EmployeeLeaveManagement.Models.AdminLoginViewModel

@{
    ViewData["Title"] = "Admin Login";
}

<div style="max-width:420px; margin:80px auto; background:white; padding:35px; border-radius:18px; box-shadow:0 8px 30px rgba(0,0,0,0.1);">

    <h2 style="text-align:center; margin-bottom:25px; color:#2563eb;">
        Admin Login
    </h2>

    <form asp-action="Login" method="post">

        <div style="margin-bottom:18px;">
            <label asp-for="Username"></label>
            <input asp-for="Username" class="form-control" placeholder="Enter username" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div style="margin-bottom:18px;">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <button type="submit" class="btn btn-primary w-100">
            Login
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}